---
/**
 * @component Header
 * Sticky navigation with glassmorphism effect.
 * Mobile: hamburger menu opening a full-screen drawer.
 * Active link highlighting via IntersectionObserver.
 */
import { personalInfo, navItems, socialLinks } from '../data/portfolio';

/* ------------------------------------------------------------------ */
/*  Lucide SVG icon paths (stroke-based, viewBox 0 0 24 24)           */
/* ------------------------------------------------------------------ */
const icons: Record<string, string> = {
  home: '<path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/>',
  user: '<path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/>',
  code: '<polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/>',
  graduationCap: '<path d="M22 10v6M2 10l10-5 10 5-10 5z"/><path d="M6 12v5c0 2 6 3 6 3s6-1 6-3v-5"/>',
  briefcase: '<rect width="20" height="14" x="2" y="7" rx="2" ry="2"/><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/>',
  folder: '<path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"/>',
  award: '<circle cx="12" cy="8" r="6"/><path d="M15.477 12.89 17 22l-5-3-5 3 1.523-9.11"/>',
  mail: '<rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>',
  fileText: '<path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z"/><polyline points="14 2 14 8 20 8"/><line x1="16" x2="8" y1="13" y2="13"/><line x1="16" x2="8" y1="17" y2="17"/><line x1="10" x2="8" y1="9" y2="9"/>',
  github: '<path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/>',
  linkedin: '<path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect width="4" height="12" x="2" y="9"/><circle cx="4" cy="4" r="2"/>',
  menu: '<line x1="4" x2="20" y1="12" y2="12"/><line x1="4" x2="20" y1="6" y2="6"/><line x1="4" x2="20" y1="18" y2="18"/>',
  x: '<path d="M18 6 6 18"/><path d="m6 6 12 12"/>',
  terminal: '<polyline points="4 17 10 11 4 5"/><line x1="12" x2="20" y1="19" y2="19"/>',
};

function renderIcon(name: string, size = 18): string {
  const path = icons[name] || icons.code;
  return `<svg xmlns="http://www.w3.org/2000/svg" width="${size}" height="${size}" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">${path}</svg>`;
}
---

<header class="header" id="site-header">
  <div class="header__inner">
    <!-- Logo -->
    <a href="#hero" class="header__logo" aria-label="Accueil">
      <span class="header__logo-icon" set:html={renderIcon('terminal', 22)} />
      <span class="header__logo-text">{personalInfo.firstName}</span>
    </a>

    <!-- Desktop Nav -->
    <nav class="header__nav" aria-label="Navigation principale">
      {navItems.map((item) => (
        <a href={item.href} class="header__link" data-section={item.href.replace('#', '')}>
          <span set:html={renderIcon(item.icon, 16)} />
          {item.label}
        </a>
      ))}
    </nav>

    <div class="header__actions">
      <!-- Theme Toggle -->
      <button class="header__theme-toggle" id="theme-toggle" aria-label="Changer le thème">
        <svg class="theme-icon theme-icon--sun" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/></svg>
        <svg class="theme-icon theme-icon--moon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
      </button>

      <!-- Hamburger Button -->
      <button
        class="header__hamburger"
        aria-label="Ouvrir le menu"
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <span class="header__hamburger-line"></span>
        <span class="header__hamburger-line"></span>
        <span class="header__hamburger-line"></span>
      </button>
    </div>
  </div>

  <!-- Mobile Drawer -->
  <div class="drawer" id="mobile-menu" aria-hidden="true">
    <div class="drawer__backdrop"></div>
    <div class="drawer__panel">
      <nav class="drawer__nav" aria-label="Navigation mobile">
        {navItems.map((item) => (
          <a href={item.href} class="drawer__link" data-section={item.href.replace('#', '')}>
            <span set:html={renderIcon(item.icon, 20)} />
            {item.label}
          </a>
        ))}
      </nav>
      <div class="drawer__socials">
        <!-- Theme toggle in drawer -->
        <button class="drawer__social" id="theme-toggle-mobile" aria-label="Changer le thème">
          <svg class="theme-icon theme-icon--sun" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/></svg>
          <svg class="theme-icon theme-icon--moon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
        </button>
        {socialLinks.map((link) => (
          <a href={link.url} class="drawer__social" target="_blank" rel="noopener noreferrer" aria-label={link.name}>
            <span set:html={renderIcon(link.icon, 20)} />
          </a>
        ))}
      </div>
    </div>
  </div>
</header>

<!-- Autonomous inline script for menu behaviour -->
<script>
  document.addEventListener('DOMContentLoaded', () => {
    const header = document.getElementById('site-header') as HTMLElement;
    const hamburger = header.querySelector('.header__hamburger') as HTMLButtonElement;
    const drawer = document.getElementById('mobile-menu') as HTMLElement;
    const backdrop = drawer.querySelector('.drawer__backdrop') as HTMLElement;
    const drawerLinks = drawer.querySelectorAll('.drawer__link');

    /* -- Toggle drawer -- */
    function openDrawer() {
      drawer.setAttribute('aria-hidden', 'false');
      hamburger.setAttribute('aria-expanded', 'true');
      hamburger.classList.add('is-active');
      document.body.style.overflow = 'hidden';
    }

    function closeDrawer() {
      drawer.setAttribute('aria-hidden', 'true');
      hamburger.setAttribute('aria-expanded', 'false');
      hamburger.classList.remove('is-active');
      document.body.style.overflow = '';
    }

    hamburger.addEventListener('click', () => {
      const isOpen = drawer.getAttribute('aria-hidden') === 'false';
      isOpen ? closeDrawer() : openDrawer();
    });

    backdrop.addEventListener('click', closeDrawer);
    drawerLinks.forEach((link) => link.addEventListener('click', closeDrawer));

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') closeDrawer();
    });

    /* -- Header shrink on scroll -- */
    let lastScroll = 0;
    const onScroll = () => {
      const scrollY = window.scrollY;
      header.classList.toggle('header--scrolled', scrollY > 50);
      lastScroll = scrollY;
    };
    window.addEventListener('scroll', onScroll, { passive: true });
    onScroll();

    /* -- Active link via IntersectionObserver -- */
    const sections = document.querySelectorAll('section[id]');
    const headerLinks = header.querySelectorAll('.header__link, .drawer__link');

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            const id = entry.target.getAttribute('id');
            headerLinks.forEach((link) => {
              link.classList.toggle('is-active', link.getAttribute('data-section') === id);
            });
          }
        });
      },
      { rootMargin: '-20% 0px -60% 0px', threshold: 0 }
    );

    sections.forEach((section) => observer.observe(section));

    /* -- Theme toggle -- */
    function getTheme() { return document.documentElement.getAttribute('data-theme') || 'dark'; }
    function setTheme(t: string) {
      document.documentElement.setAttribute('data-theme', t);
      localStorage.setItem('theme', t);
      document.querySelector('meta[name="theme-color"]')?.setAttribute('content', t==='light'?'#f8fafc':'#0a0f1e');
    }
    function toggleTheme() { setTheme(getTheme() === 'dark' ? 'light' : 'dark'); }
    document.getElementById('theme-toggle')?.addEventListener('click', toggleTheme);
    document.getElementById('theme-toggle-mobile')?.addEventListener('click', toggleTheme);
  });
</script>

<style>
  /* ============================================================ */
  /*  Header                                                        */
  /* ============================================================ */
  .header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 1000;
    height: var(--header-height);
    background: rgba(10, 15, 30, 0.8);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border-bottom: 1px solid var(--glass-border);
    transition: height 0.3s ease, background 0.3s ease;
  }

  .header--scrolled {
    height: 60px;
    background: rgba(10, 15, 30, 0.95);
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.3);
  }

  .header__inner {
    max-width: var(--max-width);
    margin: 0 auto;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 24px;
  }

  .header__actions {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .header__theme-toggle {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 38px;
    height: 38px;
    background: rgba(99, 102, 241, 0.08);
    border: 1px solid var(--glass-border);
    border-radius: var(--radius-sm);
    color: var(--color-text-muted);
    cursor: pointer;
    transition: all 0.2s;
  }
  .header__theme-toggle:hover {
    color: var(--color-primary-light);
    background: rgba(99, 102, 241, 0.15);
  }

  /* Sun shown in dark mode, moon in light mode */
  .theme-icon--moon { display: none; }
  :global(html[data-theme='light']) .theme-icon--sun { display: none; }
  :global(html[data-theme='light']) .theme-icon--moon { display: block; }

  /* Logo */
  .header__logo {
    display: flex;
    align-items: center;
    gap: 10px;
    font-weight: 700;
    font-size: 1.1rem;
    color: var(--color-text-heading);
    transition: color 0.2s;
  }

  .header__logo:hover {
    color: var(--color-primary-light);
  }

  .header__logo-icon {
    display: flex;
    color: var(--color-primary-light);
  }

  /* Desktop nav */
  .header__nav {
    display: flex;
    align-items: center;
    gap: 4px;
  }

  .header__link {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 6px 14px;
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--color-text-muted);
    border-radius: var(--radius-sm);
    transition: all 0.2s ease;
  }

  .header__link:hover {
    color: var(--color-text-heading);
    background: rgba(99, 102, 241, 0.08);
  }

  .header__link.is-active {
    color: var(--color-primary-light);
    background: rgba(99, 102, 241, 0.12);
  }

  .header__link svg {
    flex-shrink: 0;
  }

  /* Hamburger */
  .header__hamburger {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    width: 40px;
    height: 40px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 8px;
    border-radius: var(--radius-sm);
    transition: background 0.2s;
  }

  .header__hamburger:hover {
    background: rgba(99, 102, 241, 0.1);
  }

  .header__hamburger-line {
    display: block;
    width: 100%;
    height: 2px;
    background: var(--color-text);
    border-radius: 2px;
    transition: all 0.3s ease;
    transform-origin: center;
  }

  .header__hamburger.is-active .header__hamburger-line:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
  }

  .header__hamburger.is-active .header__hamburger-line:nth-child(2) {
    opacity: 0;
    transform: scaleX(0);
  }

  .header__hamburger.is-active .header__hamburger-line:nth-child(3) {
    transform: translateY(-7px) rotate(-45deg);
  }

  /* ============================================================ */
  /*  Drawer (mobile menu)                                          */
  /* ============================================================ */
  .drawer {
    position: fixed;
    inset: 0;
    z-index: 999;
    pointer-events: none;
  }

  .drawer[aria-hidden='false'] {
    pointer-events: all;
  }

  .drawer__backdrop {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.5);
    backdrop-filter: blur(4px);
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .drawer[aria-hidden='false'] .drawer__backdrop {
    opacity: 1;
  }

  .drawer__panel {
    position: absolute;
    top: 0;
    right: 0;
    width: 300px;
    max-width: 85vw;
    height: 100%;
    background: rgba(10, 15, 30, 0.98);
    backdrop-filter: blur(20px);
    border-left: 1px solid var(--glass-border);
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 40px;
    padding: 60px 32px;
    transform: translateX(100%);
    transition: transform 0.35s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .drawer[aria-hidden='false'] .drawer__panel {
    transform: translateX(0);
  }

  .drawer__nav {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .drawer__link {
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 12px 16px;
    font-size: 1.05rem;
    font-weight: 500;
    color: var(--color-text-muted);
    border-radius: var(--radius-sm);
    transition: all 0.2s ease;
  }

  .drawer__link:hover,
  .drawer__link.is-active {
    color: var(--color-primary-light);
    background: rgba(99, 102, 241, 0.1);
  }

  .drawer__socials {
    display: flex;
    gap: 12px;
    padding: 0 16px;
  }

  .drawer__social {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 42px;
    height: 42px;
    border-radius: var(--radius-sm);
    background: rgba(99, 102, 241, 0.08);
    border: 1px solid var(--glass-border);
    color: var(--color-text-muted);
    transition: all 0.2s ease;
  }

  .drawer__social:hover {
    color: var(--color-primary-light);
    background: rgba(99, 102, 241, 0.15);
    transform: translateY(-2px);
  }

  /* ============================================================ */
  /*  Responsive                                                    */
  /* ============================================================ */
  :global(html[data-theme='light']) .header {
    background: rgba(248, 250, 252, 0.85);
    border-bottom-color: rgba(0, 0, 0, 0.06);
  }
  :global(html[data-theme='light']) .header--scrolled {
    background: rgba(248, 250, 252, 0.95);
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.06);
  }
  :global(html[data-theme='light']) .drawer__panel {
    background: rgba(248, 250, 252, 0.98);
    border-left-color: rgba(0, 0, 0, 0.06);
  }

  @media (max-width: 768px) {
    .header__nav {
      display: none;
    }
    .header__hamburger {
      display: flex;
    }
  }
</style>
