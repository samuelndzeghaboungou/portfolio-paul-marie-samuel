---
/**
 * @component Hero
 * Full-height hero section with gradient animated name, profile photo
 * with hue-rotate ring, action buttons, social pills, stat bar, and
 * scroll indicator.
 */
import { personalInfo, stats, socialLinks, projects, publications } from '../data/portfolio';

const icons: Record<string, string> = {
  github: '<path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/>',
  linkedin: '<path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect width="4" height="12" x="2" y="9"/><circle cx="4" cy="4" r="2"/>',
  mail: '<rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>',
  arrowDown: '<path d="m6 9 6 6 6-6"/>',
  folder: '<path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"/>',
  download: '<path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" x2="12" y1="15" y2="3"/>',
  send: '<path d="m22 2-7 20-4-9-9-4Z"/><path d="M22 2 11 13"/>',
  mousePointer: '<path d="M3 3v18h18"/>', // placeholder
};

function renderIcon(name: string, size = 18): string {
  const path = icons[name] || '';
  return `<svg xmlns="http://www.w3.org/2000/svg" width="${size}" height="${size}" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">${path}</svg>`;
}

// Action buttons – adaptive
const actionButtons = [
  ...(projects.length > 0 ? [{ label: 'Voir mes Projets', href: '#projects', icon: 'folder', variant: 'primary' }] : []),
  { label: 'Télécharger mon CV', href: '#resume-export', icon: 'download', variant: 'ghost', isResumeBtn: true },
  { label: 'Me Contacter', href: '#contact', icon: 'send', variant: 'ghost' },
];
---

<section id="hero" class="hero">
  <div class="hero__container">
    <div class="hero__content">
      <!-- Availability badge -->
      <div class="hero__badge reveal">
        <span class="hero__badge-dot"></span>
        {personalInfo.availabilityBadge}
      </div>

      <!-- Name -->
      <h1 class="hero__name reveal">
        <span class="hero__firstname gradient-text">{personalInfo.firstName}</span>
        <span class="hero__lastname">{personalInfo.lastName}</span>
      </h1>

      <!-- Title & subtitle -->
      <p class="hero__title reveal">{personalInfo.title}</p>
      <p class="hero__subtitle reveal">{personalInfo.subtitle}</p>

      <!-- Action buttons -->
      <div class="hero__actions reveal">
        {actionButtons.map((btn) => (
          btn.isResumeBtn ? (
            <button
              class={`hero__btn hero__btn--${btn.variant}`}
              id="open-resume-modal-btn"
              type="button"
            >
              <span set:html={renderIcon(btn.icon, 18)} />
              {btn.label}
            </button>
          ) : (
            <a
              href={btn.href}
              class={`hero__btn hero__btn--${btn.variant}`}
              {...(btn.href.startsWith('http') || btn.href.endsWith('.pdf') ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
            >
              <span set:html={renderIcon(btn.icon, 18)} />
              {btn.label}
            </a>
          )
        ))}
      </div>

      <script>
        document.getElementById('open-resume-modal-btn')?.addEventListener('click', () => {
          window.dispatchEvent(new Event('open-resume-modal'));
        });
      </script>

      <!-- Social pills -->
      <div class="hero__socials reveal">
        {socialLinks.map((link) => (
          <a href={link.url} class="hero__social-pill" target="_blank" rel="noopener noreferrer">
            <span set:html={renderIcon(link.icon, 16)} />
            {link.name}
          </a>
        ))}
      </div>
    </div>

    <!-- Profile photo -->
    <div class="hero__photo-wrapper reveal">
      <div class="hero__photo-ring">
        <img
          src={personalInfo.avatar}
          alt={`Photo de ${personalInfo.firstName} ${personalInfo.lastName}`}
          class="hero__photo"
          width="280"
          height="280"
          loading="eager"
        />
      </div>
    </div>
  </div>

  <!-- Stats bar -->
  <div class="hero__stats reveal">
    {stats.map((stat) => (
      <div class="hero__stat">
        <span class="hero__stat-value gradient-text">{stat.value}</span>
        <span class="hero__stat-label">{stat.label}</span>
      </div>
    ))}
  </div>

  <!-- Scroll indicator -->
  <div class="hero__scroll-indicator reveal" aria-hidden="true">
    <div class="hero__mouse">
      <div class="hero__mouse-wheel"></div>
    </div>
  </div>
</section>

<style>
  /* ============================================================ */
  /*  Hero                                                          */
  /* ============================================================ */
  .hero {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    padding: 120px 24px 60px;
    position: relative;
  }

  .hero__container {
    max-width: var(--max-width);
    width: 100%;
    display: grid;
    grid-template-columns: 1fr auto;
    align-items: center;
    gap: 60px;
  }

  /* -- Badge -- */
  .hero__badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 6px 16px;
    background: rgba(34, 197, 94, 0.08);
    border: 1px solid rgba(34, 197, 94, 0.2);
    border-radius: 999px;
    font-size: 0.82rem;
    font-weight: 500;
    color: var(--color-success);
    margin-bottom: 24px;
    width: fit-content;
  }

  .hero__badge-dot {
    width: 8px;
    height: 8px;
    background: var(--color-success);
    border-radius: 50%;
    animation: pulse 2s ease-in-out infinite;
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; box-shadow: 0 0 0 0 rgba(34, 197, 94, 0.4); }
    50% { opacity: 0.8; box-shadow: 0 0 0 8px rgba(34, 197, 94, 0); }
  }

  /* -- Name -- */
  .hero__name {
    font-size: clamp(2.2rem, 6vw, 3.8rem);
    font-weight: 900;
    line-height: 1.1;
    margin-bottom: 16px;
  }

  .hero__firstname {
    display: block;
  }

  .hero__lastname {
    display: block;
    color: var(--color-text-heading);
  }

  /* -- Title & subtitle -- */
  .hero__title {
    font-size: clamp(1rem, 2.5vw, 1.3rem);
    font-weight: 600;
    color: var(--color-primary-light);
    margin-bottom: 8px;
  }

  .hero__subtitle {
    font-size: 1rem;
    color: var(--color-text-muted);
    max-width: 520px;
    margin-bottom: 32px;
    line-height: 1.6;
  }

  /* -- Action buttons -- */
  .hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-bottom: 24px;
  }

  .hero__btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 12px 24px;
    font-size: 0.9rem;
    font-weight: 600;
    border-radius: var(--radius-sm);
    transition: all 0.3s ease;
    cursor: pointer;
    border: none;
  }

  .hero__btn--primary {
    background: var(--gradient-primary);
    color: #fff;
    box-shadow: 0 4px 15px rgba(99, 102, 241, 0.3);
  }

  .hero__btn--primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 25px rgba(99, 102, 241, 0.5);
    color: #fff;
  }

  .hero__btn--ghost {
    background: rgba(99, 102, 241, 0.08);
    color: var(--color-text);
    border: 1px solid var(--color-border);
  }

  .hero__btn--ghost:hover {
    background: rgba(99, 102, 241, 0.15);
    border-color: var(--color-primary);
    transform: translateY(-2px);
    color: var(--color-text-heading);
  }

  /* -- Social pills -- */
  .hero__socials {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }

  .hero__social-pill {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 6px 14px;
    background: var(--glass-bg);
    border: 1px solid var(--glass-border);
    border-radius: 999px;
    font-size: 0.8rem;
    font-weight: 500;
    color: var(--color-text-muted);
    backdrop-filter: blur(8px);
    transition: all 0.25s ease;
  }

  .hero__social-pill:hover {
    color: var(--color-primary-light);
    border-color: var(--color-primary);
    background: rgba(99, 102, 241, 0.1);
    transform: translateY(-2px);
  }

  /* -- Profile photo -- */
  .hero__photo-wrapper {
    display: flex;
    justify-content: center;
  }

  .hero__photo-ring {
    position: relative;
    width: 280px;
    height: 280px;
    border-radius: 50%;
    padding: 5px;
    background: var(--gradient-primary);
    animation: hueRotate 8s linear infinite;
  }

  @keyframes hueRotate {
    0% { filter: hue-rotate(0deg); }
    100% { filter: hue-rotate(360deg); }
  }

  .hero__photo {
    width: 100%;
    height: 100%;
    border-radius: 50%;
    object-fit: cover;
    border: 4px solid var(--color-bg);
    transition: transform 0.5s cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  .hero__photo-ring:hover .hero__photo {
    transform: scale(1.05);
  }

  /* -- Stats bar -- */
  .hero__stats {
    max-width: var(--max-width);
    width: 100%;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 24px;
    margin-top: 60px;
    padding: 32px;
    background: var(--glass-bg);
    backdrop-filter: blur(var(--glass-blur));
    border: 1px solid var(--glass-border);
    border-radius: var(--radius);
  }

  .hero__stat {
    text-align: center;
  }

  .hero__stat-value {
    display: block;
    font-size: 1.8rem;
    font-weight: 800;
    line-height: 1.2;
  }

  .hero__stat-label {
    font-size: 0.78rem;
    color: var(--color-text-muted);
    font-weight: 500;
  }

  /* -- Scroll indicator -- */
  .hero__scroll-indicator {
    margin-top: 40px;
    display: flex;
    justify-content: center;
  }

  .hero__mouse {
    width: 26px;
    height: 40px;
    border: 2px solid var(--color-border-hover);
    border-radius: 13px;
    display: flex;
    justify-content: center;
    padding-top: 8px;
  }

  .hero__mouse-wheel {
    width: 3px;
    height: 8px;
    background: var(--color-primary-light);
    border-radius: 2px;
    animation: scrollWheel 2s ease-in-out infinite;
  }

  @keyframes scrollWheel {
    0% { opacity: 1; transform: translateY(0); }
    100% { opacity: 0; transform: translateY(10px); }
  }

  /* ============================================================ */
  /*  Responsive                                                    */
  /* ============================================================ */
  @media (max-width: 768px) {
    .hero {
      padding: 100px 16px 40px;
    }

    .hero__container {
      grid-template-columns: 1fr;
      text-align: center;
      gap: 40px;
    }

    .hero__photo-wrapper {
      order: -1;
    }

    .hero__photo-ring {
      width: 200px;
      height: 200px;
    }

    .hero__badge {
      margin: 0 auto 20px;
    }

    .hero__subtitle {
      margin: 0 auto 24px;
    }

    .hero__actions {
      justify-content: center;
    }

    .hero__socials {
      justify-content: center;
    }

    .hero__stats {
      grid-template-columns: repeat(2, 1fr);
      padding: 20px;
      gap: 16px;
      margin-top: 40px;
    }

    .hero__stat-value {
      font-size: 1.4rem;
    }
  }
</style>
