---
/**
 * @component Projects
 * Grid of project cards with decorative numbering, tech tags, and hover effects.
 */
import { projects } from '../data/portfolio';

const externalLinkIcon = '<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" x2="21" y1="14" y2="3"/></svg>';
const arrowRight = '<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>';
const githubIcon = '<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/></svg>';
---

{projects.length > 0 && (
  <section id="projects" class="section">
    <div class="proj__header reveal">
      <span class="section__label">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"/></svg>
        Projets
      </span>
      <h2 class="section__title">Mes Réalisations</h2>
      <p class="section__subtitle">Des projets concrets qui démontrent mes compétences techniques et ma créativité.</p>
    </div>

    <div class="proj__grid stagger-children">
      {projects.map((project, i) => (
        <div class="proj__card reveal">
          <div class="proj__card-top"></div>
          <span class="proj__number gradient-text">{String(i + 1).padStart(2, '0')}</span>
          <h3 class="proj__title">
            {project.url ? (
              <a href={project.url} target="_blank" rel="noopener noreferrer">
                {project.title}
                <span set:html={externalLinkIcon} />
              </a>
            ) : (
              project.title
            )}
          </h3>
          <p class="proj__desc">{project.description}</p>
          <div class="proj__tags">
            {project.tags.map((tag) => (
              <span class="proj__tag">{tag}</span>
            ))}
          </div>
          <div class="proj__links">
            {project.github && (
              <a href={project.github} class="proj__link" target="_blank" rel="noopener noreferrer">
                <span set:html={githubIcon} />
                Code Source
              </a>
            )}
            {project.url && (
              <a href={project.url} class="proj__link proj__link--primary" target="_blank" rel="noopener noreferrer">
                View Project
                <span class="proj__arrow" set:html={arrowRight} />
              </a>
            )}
          </div>
        </div>
      ))}
    </div>
  </section>
)}

<style>
  .proj__grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
    gap: 20px;
  }

  .proj__card {
    position: relative;
    padding: 32px;
    background: var(--glass-bg);
    backdrop-filter: blur(var(--glass-blur));
    border: 1px solid var(--glass-border);
    border-radius: var(--radius);
    overflow: hidden;
    transition: all 0.3s ease;
    display: flex;
    flex-direction: column;
  }

  .proj__card-top {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: var(--gradient-card-top);
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .proj__card:hover {
    transform: translateY(-4px);
    border-color: var(--color-border-hover);
    box-shadow: var(--shadow-lg);
  }

  .proj__card:hover .proj__card-top {
    opacity: 1;
  }

  .proj__number {
    font-size: 2.5rem;
    font-weight: 900;
    line-height: 1;
    opacity: 0.15;
    margin-bottom: -10px;
    font-family: var(--font-mono);
  }

  .proj__title {
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--color-text-heading);
    margin-bottom: 10px;
  }

  .proj__title a {
    color: inherit;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    transition: color 0.2s;
  }

  .proj__title a:hover {
    color: var(--color-primary-light);
  }

  .proj__desc {
    font-size: 0.88rem;
    color: var(--color-text-muted);
    line-height: 1.6;
    margin-bottom: 16px;
    flex: 1;
  }

  .proj__tags {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    margin-bottom: 18px;
  }

  .proj__tag {
    padding: 3px 10px;
    font-size: 0.7rem;
    font-weight: 500;
    color: var(--color-accent-light);
    background: rgba(168, 85, 247, 0.08);
    border: 1px solid rgba(168, 85, 247, 0.15);
    border-radius: 999px;
  }

  .proj__links {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
  }

  .proj__link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 0.82rem;
    font-weight: 600;
    color: var(--color-text-muted);
    padding: 6px 14px;
    border-radius: var(--radius-sm);
    border: 1px solid var(--color-border);
    transition: all 0.2s ease;
  }

  .proj__link:hover {
    color: var(--color-text-heading);
    border-color: var(--color-border-hover);
    background: rgba(99, 102, 241, 0.06);
  }

  .proj__link--primary {
    color: var(--color-primary-light);
    border-color: rgba(99, 102, 241, 0.3);
  }

  .proj__link--primary:hover {
    background: rgba(99, 102, 241, 0.1);
    color: var(--color-primary-light);
  }

  .proj__arrow {
    display: inline-flex;
    transition: transform 0.2s ease;
  }

  .proj__link--primary:hover .proj__arrow {
    transform: translateX(4px);
  }

  @media (max-width: 768px) {
    .proj__grid {
      grid-template-columns: 1fr;
    }

    .proj__card {
      padding: 24px;
    }
  }
</style>
