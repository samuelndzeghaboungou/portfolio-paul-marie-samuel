---
/**
 * @component Skills
 * Technical skills grid with icon cards and optional soft skills section.
 */
import { technicalSkills, softSkills } from '../data/portfolio';

const icons: Record<string, string> = {
  code: '<polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/>',
  layout: '<rect width="18" height="18" x="3" y="3" rx="2" ry="2"/><line x1="3" x2="21" y1="9" y2="9"/><line x1="9" x2="9" y1="21" y2="9"/>',
  server: '<rect width="20" height="8" x="2" y="2" rx="2" ry="2"/><rect width="20" height="8" x="2" y="14" rx="2" ry="2"/><line x1="6" x2="6.01" y1="6" y2="6"/><line x1="6" x2="6.01" y1="18" y2="18"/>',
  database: '<ellipse cx="12" cy="5" rx="9" ry="3"/><path d="M3 5V19A9 3 0 0 0 21 19V5"/><path d="M3 12A9 3 0 0 0 21 12"/>',
  smartphone: '<rect width="14" height="20" x="5" y="2" rx="2" ry="2"/><line x1="12" x2="12.01" y1="18" y2="18"/>',
  gitBranch: '<line x1="6" x2="6" y1="3" y2="15"/><circle cx="18" cy="6" r="3"/><circle cx="6" cy="18" r="3"/><path d="M18 9a9 9 0 0 1-9 9"/>',
  brain: '<path d="M9.5 2A2.5 2.5 0 0 1 12 4.5v15a2.5 2.5 0 0 1-4.96.44 2.5 2.5 0 0 1-2.96-3.08 3 3 0 0 1-.34-5.58 2.5 2.5 0 0 1 1.32-4.24 2.5 2.5 0 0 1 1.98-3A2.5 2.5 0 0 1 9.5 2Z"/><path d="M14.5 2A2.5 2.5 0 0 0 12 4.5v15a2.5 2.5 0 0 0 4.96.44 2.5 2.5 0 0 0 2.96-3.08 3 3 0 0 0 .34-5.58 2.5 2.5 0 0 0-1.32-4.24 2.5 2.5 0 0 0-1.98-3A2.5 2.5 0 0 0 14.5 2Z"/>',
  shield: '<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10"/>',
  users: '<path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>',
  lightbulb: '<path d="M15 14c.2-1 .7-1.7 1.5-2.5 1-.9 1.5-2.2 1.5-3.5A6 6 0 0 0 6 8c0 1 .2 2.2 1.5 3.5.7.7 1.3 1.5 1.5 2.5"/><path d="M9 18h6"/><path d="M10 22h4"/>',
  clock: '<circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>',
  messageCircle: '<path d="m3 21 1.9-5.7a8.5 8.5 0 1 1 3.8 3.8z"/>',
  target: '<circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="6"/><circle cx="12" cy="12" r="2"/>',
  zap: '<polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/>',
};

function renderIcon(name: string, size = 22): string {
  const path = icons[name] || icons.code;
  return `<svg xmlns="http://www.w3.org/2000/svg" width="${size}" height="${size}" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">${path}</svg>`;
}

const hasSoftSkills = softSkills.length > 0;
---

<section id="skills" class="section">
  <div class="skills__header reveal">
    <span class="section__label">
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>
      Compétences
    </span>
    <h2 class="section__title">Mon Arsenal Technique</h2>
    <p class="section__subtitle">Un éventail complet de compétences pour construire des solutions de bout en bout.</p>
  </div>

  <!-- Technical Skills -->
  <div class="divider">Technical Skills</div>
  <div class="skills__grid stagger-children">
    {technicalSkills.map((cat) => (
      <div class="skills__card reveal">
        <div class="skills__card-top"></div>
        <div class="skills__icon-wrap">
          <span set:html={renderIcon(cat.icon, 24)} />
        </div>
        <h3 class="skills__card-title">{cat.title}</h3>
        <div class="skills__chips">
          {cat.skills.map((skill) => (
            <span class="skills__chip">{skill}</span>
          ))}
        </div>
        <span class="skills__count">{cat.skills.length} compétences</span>
      </div>
    ))}
  </div>

  <!-- Soft Skills (optional) -->
  {hasSoftSkills && (
    <>
      <div class="divider">Soft Skills</div>
      <div class="skills__soft-grid stagger-children">
        {softSkills.map((skill) => (
          <div class="skills__soft-card reveal">
            <div class="skills__soft-icon">
              <span set:html={renderIcon(skill.icon, 20)} />
            </div>
            <div>
              <h4 class="skills__soft-name">{skill.name}</h4>
              <p class="skills__soft-desc">{skill.description}</p>
            </div>
          </div>
        ))}
      </div>
    </>
  )}
</section>

<style>
  /* ============================================================ */
  /*  Technical Skills Grid                                         */
  /* ============================================================ */
  .skills__grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 20px;
  }

  .skills__card {
    position: relative;
    padding: 28px;
    background: var(--glass-bg);
    backdrop-filter: blur(var(--glass-blur));
    border: 1px solid var(--glass-border);
    border-radius: var(--radius);
    overflow: hidden;
    transition: all 0.3s ease;
  }

  .skills__card-top {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: var(--gradient-card-top);
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .skills__card:hover {
    transform: translateY(-4px);
    border-color: var(--color-border-hover);
    box-shadow: var(--shadow-lg);
  }

  .skills__card:hover .skills__card-top {
    opacity: 1;
  }

  .skills__icon-wrap {
    width: 48px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(99, 102, 241, 0.08);
    border: 1px solid rgba(99, 102, 241, 0.15);
    border-radius: var(--radius-sm);
    color: var(--color-primary-light);
    margin-bottom: 16px;
    transition: all 0.3s ease;
  }

  .skills__card:hover .skills__icon-wrap {
    transform: scale(1.1);
    background: rgba(99, 102, 241, 0.15);
    box-shadow: 0 0 20px rgba(99, 102, 241, 0.2);
  }

  .skills__card-title {
    font-size: 1rem;
    font-weight: 700;
    color: var(--color-text-heading);
    margin-bottom: 14px;
  }

  .skills__chips {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    margin-bottom: 14px;
  }

  .skills__chip {
    padding: 4px 10px;
    font-size: 0.72rem;
    font-weight: 500;
    color: var(--color-text-muted);
    background: rgba(99, 102, 241, 0.06);
    border: 1px solid rgba(99, 102, 241, 0.1);
    border-radius: 999px;
    transition: all 0.2s ease;
  }

  .skills__card:hover .skills__chip {
    border-color: rgba(99, 102, 241, 0.2);
    color: var(--color-text);
  }

  .skills__count {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--color-text-muted);
    opacity: 0.6;
  }

  /* ============================================================ */
  /*  Soft Skills                                                   */
  /* ============================================================ */
  .skills__soft-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 16px;
  }

  .skills__soft-card {
    display: flex;
    align-items: flex-start;
    gap: 16px;
    padding: 20px;
    background: var(--glass-bg);
    backdrop-filter: blur(var(--glass-blur));
    border: 1px solid var(--glass-border);
    border-radius: var(--radius);
    transition: all 0.3s ease;
  }

  .skills__soft-card:hover {
    transform: translateY(-2px);
    border-color: var(--color-border-hover);
    box-shadow: var(--shadow-md);
  }

  .skills__soft-icon {
    flex-shrink: 0;
    width: 40px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-accent-light);
    background: rgba(168, 85, 247, 0.08);
    border: 1px solid rgba(168, 85, 247, 0.15);
    border-radius: var(--radius-xs);
    transition: all 0.3s ease;
  }

  .skills__soft-card:hover .skills__soft-icon {
    transform: scale(1.1);
    box-shadow: 0 0 15px rgba(168, 85, 247, 0.2);
  }

  .skills__soft-name {
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--color-text-heading);
    margin-bottom: 4px;
  }

  .skills__soft-desc {
    font-size: 0.82rem;
    color: var(--color-text-muted);
    line-height: 1.5;
  }

  @media (max-width: 768px) {
    .skills__grid {
      grid-template-columns: 1fr;
    }
    .skills__soft-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
